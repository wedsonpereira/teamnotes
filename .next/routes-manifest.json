    },
    {
      "page": "/api/rooms/forgot-key",
      "regex": "^/api/rooms/forgot\\-key(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/api/rooms/forgot\\-key(?:/)?$"
    },
    {
      "page": "/api/rooms/forgot-roomid",
      "regex": "^/api/rooms/forgot\\-roomid(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/api/rooms/forgot\\-roomid(?:/)?$"
    },
    {
