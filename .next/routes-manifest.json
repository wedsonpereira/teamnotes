{
  "version": 3,
  "pages404": true,
  "appType": "app",
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "priority": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    }
  ],
  "headers": [],
  "rewrites": {
    "beforeFiles": [],
    "afterFiles": [],
    "fallback": []
  },
  "dynamicRoutes": [
    {
      "page": "/api/rooms/reset-key/[token]",
      "regex": "^/api/rooms/reset\\-key/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPtoken": "nxtPtoken"
      },
      "namedRegex": "^/api/rooms/reset\\-key/(?<nxtPtoken>[^/]+?)(?:/)?$"
    },
    {
      "page": "/api/rooms/[roomId]",
      "regex": "^/api/rooms/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtProomId": "nxtProomId"
      },
      "namedRegex": "^/api/rooms/(?<nxtProomId>[^/]+?)(?:/)?$"
    },
    {
      "page": "/api/rooms/[roomId]/members",
      "regex": "^/api/rooms/([^/]+?)/members(?:/)?$",
      "routeKeys": {
        "nxtProomId": "nxtProomId"
      },
      "namedRegex": "^/api/rooms/(?<nxtProomId>[^/]+?)/members(?:/)?$"
    },
    {
      "page": "/api/rooms/[roomId]/pages",
      "regex": "^/api/rooms/([^/]+?)/pages(?:/)?$",
      "routeKeys": {
        "nxtProomId": "nxtProomId"
      },
      "namedRegex": "^/api/rooms/(?<nxtProomId>[^/]+?)/pages(?:/)?$"
    },
    {
      "page": "/api/rooms/[roomId]/pages/[pageId]",
      "regex": "^/api/rooms/([^/]+?)/pages/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtProomId": "nxtProomId",
        "nxtPpageId": "nxtPpageId"
      },
      "namedRegex": "^/api/rooms/(?<nxtProomId>[^/]+?)/pages/(?<nxtPpageId>[^/]+?)(?:/)?$"
    },
    {
      "page": "/api/rooms/[roomId]/save",
      "regex": "^/api/rooms/([^/]+?)/save(?:/)?$",
      "routeKeys": {
        "nxtProomId": "nxtProomId"
      },
      "namedRegex": "^/api/rooms/(?<nxtProomId>[^/]+?)/save(?:/)?$"
    },
    {
      "page": "/api/rooms/[roomId]/settings",
      "regex": "^/api/rooms/([^/]+?)/settings(?:/)?$",
      "routeKeys": {
        "nxtProomId": "nxtProomId"
      },
      "namedRegex": "^/api/rooms/(?<nxtProomId>[^/]+?)/settings(?:/)?$"
    },
    {
      "page": "/reset-key/[token]",
      "regex": "^/reset\\-key/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPtoken": "nxtPtoken"
      },
      "namedRegex": "^/reset\\-key/(?<nxtPtoken>[^/]+?)(?:/)?$"
    },
    {
      "page": "/room/[roomId]",
      "regex": "^/room/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtProomId": "nxtProomId"
      },
      "namedRegex": "^/room/(?<nxtProomId>[^/]+?)(?:/)?$"
    }
  ],
  "staticRoutes": [
    {
      "page": "/",
      "regex": "^/(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/(?:/)?$"
    },
    {
      "page": "/_global-error",
      "regex": "^/_global\\-error(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/_global\\-error(?:/)?$"
    },
    {
